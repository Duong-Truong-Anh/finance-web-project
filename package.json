    "react-dom": "19.2.4",
    "sass": "^1.99.0",
    "server-only": "^0.0.1",
    "ulid": "^3.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
